{
  "name": "@arcanejs/examples-theme-customization",
  "version": "0.0.0",
  "private": true,
  "description": "Example app with custom Arcane frontend themes and a custom theme switch component",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsc --noEmit && pnpm build:frontend",
    "build:frontend": "rm -rf dist && pnpm build:styles && arcane-build-frontend --entry src/frontend.tsx --outfile dist/theme-entrypoint.js --sourcemap",
    "build:styles": "tailwindcss -i ./src/theme-switch.css -o ./dist/theme-entrypoint.css",
    "start": "pnpm build:frontend && node --import=tsx src"
  },
  "devDependencies": {
    "@arcanejs/build-utils": "workspace:^",
    "@arcanejs/eslint-config": "workspace:^",
    "@tailwindcss/cli": "^4.1.13",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@types/react": "^19.2.2",
    "eslint": "^8.57.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@arcanejs/protocol": "workspace:^",
    "@arcanejs/react-toolkit": "workspace:^",
    "@arcanejs/toolkit": "workspace:^",
    "@arcanejs/toolkit-frontend": "workspace:^",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.2.0",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  }
}
